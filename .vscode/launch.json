{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET: Launch Server",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-server",
      "program": "${workspaceFolder}/server/TriviaGame/bin/Debug/net10.0/TriviaGame.dll",
      "args": [],
      "cwd": "${workspaceFolder}/server/TriviaGame",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5086"
      }
    },
    {
      "name": "Client: Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/client",
      "preLaunchTask": "client: start"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: Launch",
      "configurations": [".NET: Launch Server", "Client: Chrome"],
      "stopAll": true
    }
  ]
}
